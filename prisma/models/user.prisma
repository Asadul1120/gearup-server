
model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  password     String
  phone        String?     @unique
  profileImage String?
  address      String?

  role         UserRole    @default(CUSTOMER)
  status       UserStatus  @default(ACTIVE)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  gears Gear[]


  @@map("users")
}

enum UserRole {
  ADMIN
  CUSTOMER
  PROVIDER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}
